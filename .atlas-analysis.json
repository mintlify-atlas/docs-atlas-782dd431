  "keyFeatures": [
    "70+ production-ready React components built on Base UI primitives",
    "Design token system with CSS variables for theming and color schemes",
    "Subpath imports for optimal tree-shaking (@soft-ui/react/button)",
    "Tailwind v4 integration with utility classes",
    "TypeScript support with full type definitions",
    "Comprehensive variant system (size, tone, variant props)",
    "Built-in animation support with motion library",
    "Accessibility-first design with ARIA patterns"
  ],
  "publicApiSurface": [
    "@soft-ui/react/button - Button component with variants (primary, secondary, tertiary, ghost, link, danger)",
    "@soft-ui/react/icon-button - Icon-only button component",
    "@soft-ui/react/input - Single-line text input with prefix/suffix support",
    "@soft-ui/react/select - Dropdown selection component",
    "@soft-ui/react/checkbox - Checkbox control with indeterminate state",
    "@soft-ui/react/switch - Toggle switch component",
    "@soft-ui/react/radio-group - Radio button group",
    "@soft-ui/react/tabs - Tab navigation component",
    "@soft-ui/react/dialog - Modal dialog component",
    "@soft-ui/react/menu - Dropdown menu component",
    "@soft-ui/react/tooltip - Tooltip overlay component",
    "@soft-ui/react/badge - Status and label badges",
    "@soft-ui/react/avatar - User avatar component",
    "@soft-ui/react/table - Data table with sorting and selection",
    "@soft-ui/react/toast - Toast notification system",
    "@soft-ui/react/combobox - Searchable dropdown",
    "@soft-ui/react/autocomplete - Auto-suggestion input",
    "@soft-ui/react/slider - Range slider component",
    "@soft-ui/react/progress - Progress indicator",
    "@soft-ui/react/accordion - Collapsible content sections",
    "@soft-ui/tokens - Design tokens and CSS utilities",
    "@soft-ui/icons - Icon adapter (default: Remix Icons)"
  ]
}
