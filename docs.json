{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Soft UI",
  "theme": "palm",
  "colors": {
    "primary": "#3b82f6",
    "light": "#60a5fa",
    "dark": "#2563eb"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/saugatxyz/softui"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/saugatxyz/softui"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "installation", "quickstart"]
          },
          {
            "group": "Design System",
            "pages": ["design-system/tokens", "design-system/theming", "design-system/typography", "design-system/colors"]
          },
          {
            "group": "Components",
            "pages": [
              "components/button",
              "components/icon-button",
              "components/input",
              "components/select",
              "components/checkbox",
              "components/switch",
              "components/tabs",
              "components/dialog",
              "components/menu",
              "components/tooltip"
            ]
          },
          {
            "group": "Advanced",
            "pages": ["advanced/customization", "advanced/animations", "advanced/accessibility"]
          }
        ]
      },
      {
        "tab": "Components",
        "groups": [
          {
            "group": "Actions",
            "pages": [
              "api/button",
              "api/icon-button",
              "api/button-group",
              "api/toggle-button",
              "api/toggle-group"
            ]
          },
          {
            "group": "Forms",
            "pages": [
              "api/input",
              "api/textarea",
              "api/select",
              "api/combobox",
              "api/autocomplete",
              "api/checkbox",
              "api/radio-group",
              "api/switch",
              "api/slider",
              "api/number-field",
              "api/field",
              "api/form"
            ]
          },
          {
            "group": "Selection",
            "pages": [
              "api/tabs",
              "api/segmented-control",
              "api/checkbox-group",
              "api/switch-group",
              "api/filter",
              "api/chip"
            ]
          },
          {
            "group": "Overlays",
            "pages": [
              "api/dialog",
              "api/alert-dialog",
              "api/menu",
              "api/context-menu",
              "api/popover",
              "api/tooltip"
            ]
          },
          {
            "group": "Display",
            "pages": [
              "api/badge",
              "api/avatar",
              "api/separator",
              "api/table",
              "api/progress",
              "api/meter"
            ]
          },
          {
            "group": "Feedback",
            "pages": [
              "api/toast",
              "api/banner",
              "api/inline-notification",
              "api/empty-state"
            ]
          },
          {
            "group": "Navigation",
            "pages": [
              "api/breadcrumbs",
              "api/pagination",
              "api/accordion"
            ]
          }
